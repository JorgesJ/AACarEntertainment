<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED"/>
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD"/>
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <permission android:name="com.jorso.carapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" android:protectionLevel="signature"/>
    <uses-permission android:name="com.jorso.carapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"/>

    <queries>
        <package android:name="com.google.android.apps.maps"/>
        <package android:name="com.waze"/>
        <package android:name="com.here.app.maps"/>
        <package android:name="com.tomtom.gplay.navapp"/>
        <package android:name="com.sygic.aura"/>
        <package android:name="com.google.android.projection.gearhead"/>
        <provider android:name="androidx.car.app.connection.provider" android:authorities="androidx.car.app.connection"/>
    </queries>

    <application
        android:name=".AACarEntertainmentApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.AACarEntertainment"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true"
        android:appCategory="game"
        android:networkSecurityConfig="@xml/network_security_config"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory">

        <meta-data android:name="distractionOptimized" android:value="true"/>
        <meta-data android:name="android.max_aspect" android:value="4.0"/>
        <meta-data android:name="androidx.car.app.minCarApiLevel" android:value="7"/>

        <!-- HubActivity — punto de entrada Android Auto -->
        <activity
            android:name=".auto.HubActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:resizeableActivity="true"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.CAR_LAUNCHER"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="androidx.car.app.category.NAVIGATION"/>
                <category android:name="android.intent.category.APP_MAPS"/>
            </intent-filter>
            <layout
                android:defaultHeight="480dip"
                android:defaultWidth="800dip"
                android:gravity="fill"
                android:minHeight="1dip"
                android:minWidth="1dip"/>
            <meta-data android:name="distractionOptimized" android:value="true"/>
            <meta-data android:name="android.max_aspect" android:value="5.0"/>
        </activity>

        <!-- Launcher del móvil -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:theme="@style/Theme.AACarEntertainment.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Activities Java existentes — NO TOCAR -->
        <activity android:name=".auto.HomeActivity" android:exported="false" android:screenOrientation="landscape" android:configChanges="keyboardHidden|orientation|screenSize"/>
        <activity android:name=".auto.IptvActivity" android:exported="false" android:screenOrientation="landscape" android:configChanges="keyboardHidden|orientation|screenSize"/>
        <activity android:name=".auto.MusicActivity" android:exported="false" android:screenOrientation="landscape" android:configChanges="keyboardHidden|orientation|screenSize"/>
        <activity android:name=".auto.RadioActivity" android:exported="false" android:screenOrientation="landscape" android:configChanges="keyboardHidden|orientation|screenSize"/>
        <activity android:name=".auto.MirrorActivity2" android:exported="false" android:screenOrientation="landscape" android:configChanges="keyboardHidden|orientation|screenSize"/>
        <activity android:name=".auto.SettingsActivity" android:exported="false" android:screenOrientation="landscape" android:configChanges="keyboardHidden|orientation|screenSize"/>

        <!-- Servicio de música -->
        <service
            android:name=".auto.MusicPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService"/>
            </intent-filter>
        </service>

        <!-- Activities nuevas — nueva arquitectura -->
        <activity
            android:name=".auto.YoutubeActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <activity
            android:name=".auto.BrowserActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <activity
            android:name=".auto.RadioCarActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <activity
            android:name=".auto.MusicCarActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <activity
            android:name=".auto.IptvCarActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <activity
            android:name=".auto.VideoCarActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <activity
            android:name=".auto.FuelActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <activity
            android:name=".auto.GpsCarActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <activity
            android:name=".auto.MirrorCarActivity"
            android:exported="false"
            android:configChanges="density|layoutDirection|locale|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.AACarEntertainment"
            android:parentActivityName=".auto.HubActivity">
            <meta-data android:name="distractionOptimized" android:value="true"/>
        </activity>

        <service
            android:name=".auto.ScreenMirrorService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection"/>

        <service
            android:name=".auto.TouchForwardService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/touch_forward_config"/>
        </service>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:exported="false"
            android:authorities="com.jorso.carapp.androidx-startup"
            tools:replace="android:authorities">
            <meta-data android:name="androidx.emoji2.text.EmojiCompatInitializer" android:value="androidx.startup"/>
            <meta-data android:name="androidx.lifecycle.ProcessLifecycleInitializer" android:value="androidx.startup"/>
        </provider>

    </application>
</manifest>
