<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0A0A0C">
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/iptv_topbar" android:layout_width="0dp" android:layout_height="wrap_content" android:background="#0F0F12" android:paddingHorizontal="16dp" android:paddingTop="40dp" android:paddingBottom="8dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:id="@+id/iptv_back_container" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:background="?attr/selectableItemBackgroundBorderless" android:padding="8dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
            <ImageButton android:id="@+id/iptv_btn_back" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_home_prev" android:background="@null" android:tint="#F0EEFF" android:contentDescription="Inicio"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inicio" android:textColor="#F0EEFF" android:textSize="14sp" android:layout_marginStart="4dp"/>
        </LinearLayout>
        <TextView android:id="@+id/iptv_now_playing" android:layout_width="0dp" android:layout_height="wrap_content" android:text="IPTV" android:textColor="#A855F7" android:textSize="16sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" android:layout_marginHorizontal="8dp" app:layout_constraintStart_toEndOf="@id/iptv_back_container" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ProgressBar android:id="@+id/iptv_progress" android:layout_width="0dp" android:layout_height="3dp" style="?android:attr/progressBarStyleHorizontal" android:progressTint="#A855F7" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/iptv_topbar" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <ScrollView android:id="@+id/iptv_selector" android:layout_width="0dp" android:layout_height="0dp" android:fillViewport="true" android:clipToPadding="false" app:layout_constraintTop_toBottomOf="@id/iptv_progress" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal" android:paddingHorizontal="32dp" android:paddingTop="80dp" android:paddingBottom="32dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Selecciona tu lista IPTV" android:textColor="#F0EEFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Abre un archivo .m3u/.m3u8 o introduce una URL" android:textColor="#8888AA" android:textSize="14sp" android:gravity="center" android:layout_marginBottom="32dp"/>
            <Button android:id="@+id/iptv_btn_open_file" android:layout_width="300dp" android:layout_height="52dp" android:text="Abrir archivo .m3u" android:textColor="#F0EEFF" android:textSize="15sp" android:backgroundTint="#1AA855F7" android:layout_marginBottom="24dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="- o introduce una URL -" android:textColor="#4A4A66" android:textSize="13sp" android:layout_marginBottom="12dp"/>
            <EditText android:id="@+id/iptv_url_input" android:layout_width="300dp" android:layout_height="52dp" android:background="@drawable/home_pill_bg" android:paddingHorizontal="16dp" android:textColor="#F0EEFF" android:textSize="13sp" android:hint="https://tu-lista.m3u8" android:singleLine="true" android:imeOptions="actionGo" android:inputType="textUri" android:layout_marginBottom="12dp"/>
            <Button android:id="@+id/iptv_btn_open_url" android:layout_width="300dp" android:layout_height="52dp" android:text="Cargar URL" android:textColor="#FFFFFF" android:textSize="15sp" android:backgroundTint="#A855F7"/>
        </LinearLayout>
    </ScrollView>
    <LinearLayout android:id="@+id/iptv_player_panel" android:layout_width="0dp" android:layout_height="0dp" android:orientation="horizontal" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/iptv_progress" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/iptv_channel_list" android:layout_width="220dp" android:layout_height="match_parent" android:background="#0F0F14"/>
        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#000000">
            <androidx.media3.ui.PlayerView android:id="@+id/iptv_player_view" android:layout_width="match_parent" android:layout_height="match_parent"/>
        </FrameLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>