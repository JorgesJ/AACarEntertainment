<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/home_root" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/home_bg" android:keepScreenOn="true">
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/home_topbar" android:layout_width="0dp" android:layout_height="wrap_content" android:paddingHorizontal="20dp" android:paddingTop="36dp" android:paddingBottom="12dp" android:background="@color/home_surface" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <TextView android:id="@+id/home_logo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_logo" android:textColor="@color/home_text_primary" android:textSize="16sp" android:textStyle="bold" android:letterSpacing="0.12" android:fontFamily="sans-serif-condensed" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
        <TextView android:id="@+id/home_clock" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="@color/home_text_primary" android:textSize="22sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed" android:letterSpacing="0.04" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
        <LinearLayout android:id="@+id/home_status_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
            <TextView android:id="@+id/home_wifi_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:text="WiFi" android:textColor="@color/home_accent_green" android:textSize="11sp" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:background="@drawable/home_pill_bg" android:letterSpacing="0.04"/>
            <TextView android:id="@+id/home_temp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/home_text_secondary" android:textSize="12sp" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:background="@drawable/home_pill_bg"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/home_grid" android:layout_width="0dp" android:layout_height="0dp" android:padding="12dp" android:clipToPadding="false" android:overScrollMode="never" app:layout_constraintTop_toBottomOf="@id/home_topbar" app:layout_constraintBottom_toTopOf="@id/home_miniplayer" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/home_miniplayer" android:layout_width="0dp" android:layout_height="58dp" android:layout_marginHorizontal="12dp" android:layout_marginBottom="10dp" android:paddingHorizontal="14dp" android:background="@drawable/home_miniplayer_bg" android:visibility="gone" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <ImageView android:id="@+id/mp_art" android:layout_width="38dp" android:layout_height="38dp" android:background="@drawable/home_art_bg" android:scaleType="centerCrop" android:src="@drawable/ic_home_music" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
        <LinearLayout android:id="@+id/mp_info" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginHorizontal="12dp" app:layout_constraintStart_toEndOf="@id/mp_art" app:layout_constraintEnd_toStartOf="@id/mp_controls" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
            <TextView android:id="@+id/mp_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sin reproduccion" android:textColor="@color/home_text_primary" android:textSize="13sp" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/mp_artist" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textColor="@color/home_text_hint" android:textSize="11sp" android:maxLines="1" android:ellipsize="end"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/mp_controls" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
            <ImageButton android:id="@+id/mp_prev" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_home_prev" android:background="?attr/selectableItemBackgroundBorderless" android:tint="@color/home_text_secondary" android:contentDescription="Anterior"/>
            <ImageButton android:id="@+id/mp_play_pause" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_home_play" android:background="@drawable/home_play_btn_bg" android:tint="@color/home_text_primary" android:contentDescription="Play"/>
            <ImageButton android:id="@+id/mp_next" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_home_next" android:background="?attr/selectableItemBackgroundBorderless" android:tint="@color/home_text_secondary" android:contentDescription="Siguiente"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>