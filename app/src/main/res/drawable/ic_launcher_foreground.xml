<?xml version="1.0" encoding="utf-8"?>
<!--
    Icono foreground del launcher.
    Fondo: primary_dark (#4B44CC) configurado en ic_launcher.xml
    Foreground: triángulo play blanco (idéntica lógica al APK de referencia)
    + letra "AA" para diferenciarlo
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Fondo degradado -->
    <path
        android:fillColor="#FF4B44CC"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

    <!-- Círculo de acento -->
    <path
        android:fillColor="#FF6C63FF"
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0" />

    <!-- Triángulo play blanco -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M44,40 L44,68 L70,54 Z" />

</vector>
